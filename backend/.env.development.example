PORT=3001
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Legacy APIs are disabled by default. Enable only when legacy flow is needed.
ENABLE_LEGACY_ASSIGNMENTS_API=false
ENABLE_LEGACY_UPLOAD_API=false

# Express の req.ip 解決に使う trust proxy 設定。
# false = 直接公開 / プロキシなし
# 1 = 1段の trusted proxy / load balancer / CDN の後ろ
# render.com などのプロキシ環境で動かす場合は 1 にする
TRUST_PROXY=false

# Optional bucket overrides
# SUPABASE_NOTES_IMAGE_BUCKET=notes
# SUPABASE_AVATARS_IMAGE_BUCKET=avatars
# SUPABASE_ASSIGNMENTS_IMAGE_BUCKET=assignments
