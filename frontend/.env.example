# ==========================================
# Supabase (公開。ブラウザから参照される)
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==========================================
# Backend API
# ==========================================
# クライアント側のブラウザリクエストに使用
# 開発環境: http://localhost:3001/api
# 本番環境: デプロイ環境に応じて backend API の公開URL を指定
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3001/api

# Server-side rendering / API routes でのみ使用（オプション）
# 未設定の場合は NEXT_PUBLIC_BACKEND_API_URL にフォールバック
# BACKEND_API_URL=http://localhost:3001/api
